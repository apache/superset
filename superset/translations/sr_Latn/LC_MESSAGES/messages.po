# de, es, fa, fr, ja, lv, mi, nl, pl, pt_BR, ru, sk, sl, uk]
msgid ""
"The color scheme is determined by the related dashboard.\n"
"        Edit the color scheme in the dashboard properties."
msgstr ""
"Šemu boja određuje povezana kontrolna tabla.\n"
"        Izmenite šemu boja u svojstvima kontrolne table."

# lv, ru, sk, uk]
