msgstr ""
"Boja koja se koristi kada vrednost ne odgovara nijednoj definisanoj "
"prekidnoj tački."

# ja, lv, mi, ru, sk, uk]
msgid ""
"The colors of this chart might be overridden by custom label colors of the related dashboard.\n"
