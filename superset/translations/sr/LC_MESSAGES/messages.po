# de, es, fa, fr, ja, lv, mi, nl, pl, pt_BR, ru, sk, sl, uk, zh, zh_TW]
msgid ""
"This can be either an IP address (e.g. 127.0.0.1) or a domain name (e.g. "
"mydatabase.com)."
msgstr ""
"Ово може бити или IP адреса (нпр. 127.0.0.1) или име домена (нпр. "
"mydatabase.com)."

# es, fa, fr, ja, lv, mi, nl, pl, ru, sk, sl, tr, uk, zh, zh_TW]
msgid ""
"This chart applies cross-filters to charts whose datasets contain columns "
"with the same name."
msgstr ""
