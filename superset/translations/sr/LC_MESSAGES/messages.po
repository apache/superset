# ja, lv, mi, ru, sk, uk]
msgid "Whether to display the total value in the tooltip"
msgstr "Да ли приказати укупну вредност у облачићу"

# de, es, fa, fr, ja, lv, mi, nl, pl, pt_BR, ru, sk, sl, uk, zh, zh_TW]
msgid "Whether to display the trend line"
msgstr "Да ли приказати линију тренда"

# ja, lv, mi, ru, sk, uk]
msgid "Whether to display the type icon (#, Δ, %)"
msgstr "Да ли приказати икону типа (#, Δ, %)"

# de, es, fa, fr, ja, lv, mi, nl, pl, pt_BR, ru, sk, sl, uk, zh, zh_TW]
msgid "Whether to enable changing graph position and scaling."
msgstr "Да ли омогућити промену положаја и скалирање графика."

# de, es, fa, fr, ja, lv, mi, nl, pl, pt_BR, ru, sk, sl, uk, zh, zh_TW]
msgid "Whether to enable node dragging in force layout mode."
msgstr ""
"Да ли омогућити превлачење чворова у режиму распореда заснованог на силама."

# de, es, fa, fr, ja, lv, mi, nl, pl, pt_BR, ru, sk, sl, uk]
msgid "Whether to fill the objects"
msgstr "Да ли попунити објекте"

# de, es, fa, fr, ja, lv, mi, nl, pl, pt_BR, ru, sk, sl, uk]
