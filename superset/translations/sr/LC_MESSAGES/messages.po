msgstr "Да ли приказати минималне и максималне вредности Y осе"

msgid "Whether to display the numbered column"
msgstr "Да ли приказати нумерисану колону"

# de, es, fa, fr, ja, lv, mi, nl, pl, pt_BR, ru, sk, sl, uk, zh, zh_TW]
msgid "Whether to display the numerical values within the cells"
msgstr "Да ли приказати нумеричке вредности у ћелијама"

# fr, ja, lv, mi, ru, sk, uk]
msgid "Whether to display the percentage value in the tooltip"
msgstr "Да ли приказати процентуалну вредност у облачићу"

# de, es, fa, ja, lv, mi, nl, pl, pt_BR, ru, sk, sl, uk]
