# de, es, fa, fr, ja, lv, mi, nl, pt_BR, ru, sk, sl, uk]
msgid ""
"Duration (in seconds) of the caching timeout for charts of this database. A "
"timeout of 0 indicates that the cache never expires, and -1 bypasses the "
"cache. Note this defaults to the global timeout if undefined."
msgstr ""
"Трајање (у секундама) временског ограничења кеширања за графиконе ове базе "
"података. Вредност 0 значи да кеш никада не истиче, а -1 заобилази кеш. "
"Имајте на уму да се подразумевано користи глобално временско ограничење ако "
"није дефинисано."

# de, es, fa, fr, ja, lv, mi, nl, pt_BR, ru, sk, sl, uk]
msgid ""
"Duration (in seconds) of the caching timeout for this chart. Set to -1 to "
"bypass the cache. Note this defaults to the dataset's timeout if undefined."
msgstr ""
"Трајање (у секундама) временског ограничења кеширања за овај графикон. "
"Поставите на -1 да заобиђете кеш. Имајте на уму да се подразумевано користи "
"временско ограничење скупа података ако није дефинисано."

# de, es, fa, fr, ja, lv, mi, nl, pl, pt_BR, ru, sk, sl, uk, zh, zh_TW]
msgid ""
"Duration (in seconds) of the metadata caching timeout for schemas of this "
"database. If left unset, the cache never expires."
msgstr ""
"Трајање (у секундама) временског ограничења кеширања метаподатака за шеме "
"ове базе података. Ако није подешено, кеш никада не истиче."

# de, es, fa, fr, ja, lv, mi, nl, pl, ru, sk, sl, uk, zh, zh_TW]
msgid ""
