{
    "compilerOptions": {
      "rootDir": "src",
      "outDir": "dist",
      "target": "esnext",
      "module": "nodenext",
      "moduleResolution": "nodenext",
      "esModuleInterop": true,
      "strict": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*"]
  }
