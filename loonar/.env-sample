# =============================
# TEMPO MÁXIMO DE ESPERA DA SESSÃO AUTENTICADA
# =============================
AUTH_SESSION_TIMEOUT=20

# =============================
# BLOCO: CONFIGURAÇÃO DE HOST E DOMÍNIO
# =============================
SUPERSET_HOST=superset.loonar.cloud
# Prefixo absoluto opcional para servir assets estáticos (ex: CDN). Use esquema+host.
STATIC_ASSETS_PREFIX=
# Lista separada por vírgulas de hosts extras permitidos no CSP (use esquema+host)
CSP_ADDITIONAL_HOSTS=

# =============================
# BLOCO: AUTENTICAÇÃO
# =============================
# Alternar entre formulário de login original (superset) e customizado para LDAP (ldap)
# Use 'superset' para o formulário padrão do Superset
# Use 'ldap' para o formulário customizado integrado com Active Directory
SUPERSET_LOGIN_FORM_TYPE=superset

# =============================
# BLOCO: VARIÁVEIS DE AMBIENTE DE DESENVOLVIMENTO E EXEMPLOS
# ATENÇÃO: Use apenas em ambientes de desenvolvimento!
# =============================
# Permite print() no Python dentro do Docker
PYTHONUNBUFFERED=1
# Nome do projeto Docker Compose
COMPOSE_PROJECT_NAME=loonar
# Ativa modo de desenvolvimento
DEV_MODE=false
# Caminho Python customizado para desenvolvimento
PYTHONPATH=/app/pythonpath:/app/docker/pythonpath_dev
# Ativa recursos de debug do Flask
FLASK_DEBUG=false
# Controla o nível de log do Superset
SUPERSET_LOG_LEVEL=INFO
# Porta do Superset para desenvolvimento
SUPERSET_PORT=8088
# Ambiente do Superset
SUPERSET_ENV=development
# Carregar exemplos no Superset
SUPERSET_LOAD_EXAMPLES=no
# Ativa Cypress para testes end-to-end
CYPRESS_CONFIG=false
# Ativa Playwright para testes
ENABLE_PLAYWRIGHT=false
# Pular download do Chromium para Puppeteer
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
# Build do frontend no Docker
BUILD_SUPERSET_FRONTEND_IN_DOCKER=true
# Chave de API do Mapbox para mapas
# CHANGE THIS! [ROTATABLE]
MAPBOX_API_KEY=__ROTATE_ME__

# =============================
# BLOCO: VARIÁVEIS DE EXEMPLOS DE BANCO DE DADOS (DEV/EXEMPLOS)
# ATENÇÃO: Use apenas em ambientes de desenvolvimento!
# =============================
EXAMPLES_DB=examples
EXAMPLES_HOST=db
EXAMPLES_USER=examples
# CHANGE THIS! [ROTATABLE]
EXAMPLES_PASSWORD=__ROTATE_ME__
EXAMPLES_PORT=5432


# =============================
# BLOCO: VARIÁVEIS DE BANCO DE DADOS (POSTGRES E CONEXÃO SUPERESET)
# ATENÇÃO:
# - As variáveis POSTGRES_* são usadas para inicializar o container do banco Postgres no Docker Compose.
# - As variáveis DATABASE_* são usadas pelo Superset para se conectar ao banco de metadados.
# - Em ambientes Docker, normalmente o Superset conecta ao Postgres do próprio Compose, então ambos os grupos são necessários.
# - Se usar banco externo, apenas DATABASE_* será relevante para o Superset.
# =============================
# POSTGRES_*: configura o banco Postgres do container
POSTGRES_DB=superset
POSTGRES_USER=superset
# CHANGE THIS! [ROTATABLE]
POSTGRES_PASSWORD=__ROTATE_ME__
# DATABASE_*: configura a conexão do Superset ao banco de metadados
DATABASE_DB=superset
DATABASE_HOST=db
DATABASE_USER=superset
# CHANGE THIS! [ROTATABLE]
DATABASE_PASSWORD=__ROTATE_ME__
DATABASE_PORT=5432
DATABASE_DIALECT=postgresql

# =============================
# BLOCO: VARIÁVEIS DE REDIS
# =============================
REDIS_HOST=redis
REDIS_PORT=6379
# CHANGE THIS! [ROTATABLE]
REDIS_PASSWORD=__ROTATE_ME__

# =============================
# BLOCO: SEGURANÇA E CHAVES SENSÍVEIS
# ATENÇÃO: Troque para valores seguros em produção!
# =============================
# CHANGE THIS! [ROTATABLE]
SUPERSET_SECRET_KEY=__ROTATE_ME__
# Caminho raiz do Superset
SUPERSET_APP_ROOT="/"
# Caminho absoluto do superset_config.py customizado
SUPERSET_CONFIG_PATH=/app/pythonpath/superset_config.py

# =============================
# BLOCO: CERTIFICADOS TLS/SSL (NGINX)
# =============================
# Caminhos dos certificados montados em /etc/nginx/certs
# Em produção, ajuste conforme seus arquivos
SSL_CERT=/etc/nginx/certs/fullchain.pem
SSL_KEY=/etc/nginx/certs/privkey.pem
SSL_TRUSTED=/etc/nginx/certs/ca-bundle.crt

# =============================
# BLOCO: AUTENTICAÇÃO VIA ACTIVE DIRECTORY (LDAP)
# =============================
LOONAR_LDAP_MODE=mock

# Configuração do servidor real (produção)
LOONAR_LDAP_SERVER_REAL=ldap://127.0.0.1:389
LOONAR_LDAP_BIND_DN_REAL=CN=Morpheus Serviços,OU=BR-BH,OU=03-SERVICOS,DC=loonardc,DC=local
# CHANGE THIS! [ROTATABLE]
LOONAR_LDAP_BIND_PASSWORD_REAL=__ROTATE_ME__
# Pode ser valor único (compatibilidade):
# LOONAR_LDAP_USER_BASE_REAL=OU=04-CLIENTES,DC=loonardc,DC=local
# Ou JSON com alias para exibir no dropdown da tela de login LDAP:
LOONAR_LDAP_USER_BASE_REAL={"Cliente":"OU=04-CLIENTES,DC=loonardc,DC=local","Administrador":"OU=04-USUARIOS,DC=loonardc,DC=local"}
LOONAR_LDAP_GROUP_BASE_REAL=OU=04-CLIENTES,DC=loonardc,DC=local
LOONAR_LDAP_USE_SSL_REAL=false

# Configuração do servidor mock (docker-compose-ldap-mock)
LOONAR_LDAP_SERVER_MOCK=ldap://127.0.0.1:389
LOONAR_LDAP_BIND_DN_MOCK=CN=Morpheus Serviços,OU=BR-BH,OU=03-SERVICOS,DC=loonardc,DC=local
# CHANGE THIS! [ROTATABLE]
LOONAR_LDAP_BIND_PASSWORD_MOCK=__ROTATE_ME__
LOONAR_LDAP_USER_BASE_MOCK=OU=04-CLIENTES,DC=loonardc,DC=local
LOONAR_LDAP_GROUP_BASE_MOCK=OU=04-CLIENTES,DC=loonardc,DC=local
LOONAR_LDAP_USE_SSL_MOCK=false

# Atributos comuns
LOONAR_LDAP_UID_ATTR=sAMAccountName
LOONAR_LDAP_FIRSTNAME_ATTR=givenName
LOONAR_LDAP_LASTNAME_ATTR=sn
LOONAR_LDAP_EMAIL_ATTR=mail
LOONAR_LDAP_GROUP_FILTERTERM=CONTROLE
LOONAR_LDAP_BASE_ROLE=ROLE_BASE
LOONAR_LDAP_EMAIL_DOMAIN='<usuario>@loonardc.local'

LOONAR_SUPERSET_BASE_ROLE=Admin

# 503 quando senha incorreta
GUNICORN_TIMEOUT=120
GUNICORN_WORKERS=4
GUNICORN_WORKER_CLASS=gevent

# Aumentar pool de conexões do Superset
SQLALCHEMY_POOL_SIZE=20
SQLALCHEMY_MAX_OVERFLOW=40
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_ECHO=false

# Sincronismo de Dashboards baseado em modelo (clonagem) e roles
LOONAR_CLONE_SUPERSET_USER="admin"
LOONAR_CLONE_SUPERSET_PASS="admin"
LOONAR_CLONE_DASHBOARD_ID=1                      # Dashboard modelo (origem dos clones)
LOONAR_CLONE_DASHBOARD_PREFIX="LOONAR"           # Prefixo do nome do dashboard clonado
LOONAR_CLONE_ROLE_SUFFIX="CONTROLE"              # Sufixo do nome da role associada ao dashboard clonado