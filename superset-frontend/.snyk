# Snyk (https://snyk.io) policy file
version: v1.25.0
ignore:
  CVE-2023-30533:
    - '*':
        reason: >-
          No actionable fix available via npm. superset-frontend uses xlsx via
          SheetJS CDN (https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz),
          the most current CDN release. Snyk flags this against the unmaintained
          npm registry copy of xlsx. xlsx is only used for server-initiated data
          export, not to parse untrusted user-supplied spreadsheet input.
        expires: 2027-03-27T00:00:00.000Z
        created: 2026-03-27T00:00:00.000Z
