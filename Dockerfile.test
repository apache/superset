FROM apache/superset:latest

USER root

# Copy all Python source code at once
COPY superset /app/superset/
COPY superset-core/ /app/superset-core/

# Override config
COPY superset_config.py /app/pythonpath/superset_config.py

# Install our fork's superset-core first, then the app
# Install rison and other missing deps in the venv
RUN pip install --no-build-isolation -e /app/superset-core --no-deps && \
    pip install --no-build-isolation -e /app --no-deps && \
    pip install rison

RUN mkdir -p /app/superset_home && chown -R superset:superset /app/superset_home /app/pythonpath

USER superset
ENV SUPERSET_ENV=development
ENV SUPERSET_CONFIG_PATH=/app/pythonpath/superset_config.py

EXPOSE 8088
CMD ["sh", "-c", "superset fab create-admin --username admin --password admin --firstname Admin --lastname Superset --email admin@superset.com 2>/dev/null; superset init 2>/dev/null; superset run -p 8088 --with-threads"]
